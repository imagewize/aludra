# Directories (need /* suffix for zip -x@ to exclude recursively)
.git/*
.github/*
.claude/*
node_modules/*

# Development files
.DS_Store
.gitignore
.distignore
.gitattributes
.editorconfig
.gitkeep
phpcs.xml
phpcs.xml.dist
composer.json
composer.lock
package.json
package-lock.json
yarn.lock
pnpm-lock.yaml

# Documentation and scripts
# Kept as a guard, not a description: there is no docs/ or designs/ directory
# here any more. Planning documents and design mockups live in the private
# imagewize.com repo under docs/aludra/ and designs/aludra/ (see CLAUDE.md).
# These entries stay so that a stray file re-added here never reaches a zip.
docs/*
designs/
designs/*
bin/*
CLAUDE.md
AGENTS.md
CONTRIBUTING.md
README.md
*.sh
create-pr.sh

# Source files (keep only build/)
blocks/*/src/*
blocks/*/node_modules/*
blocks/*/package.json
blocks/*/package-lock.json
blocks/*/.gitignore
blocks/*/.npmrc
blocks/*/eslint.config.js
blocks/*/.editorconfig

