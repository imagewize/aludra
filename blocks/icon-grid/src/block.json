{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "aludra/icon-grid",
	"version": "1.0.0",
	"title": "Icon Grid",
	"category": "design",
	"icon": "grid-view",
	"description": "Responsive auto-fit grid of icon + text items with an eyebrow, title, and lead.",
	"keywords": ["icon", "grid", "checklist", "features", "list"],
	"textdomain": "aludra",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"supports": {
		"html": false,
		"align": ["wide", "full"],
		"anchor": true,
		"spacing": {
			"margin": true,
			"padding": true
		},
		"color": {
			"background": true,
			"text": true
		}
	},
	"attributes": {
		"align": {
			"type": "string",
			"default": "wide"
		}
	},
	"example": {
		"attributes": {}
	}
}
