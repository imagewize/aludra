{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "aludra/cta-columns",
  "version": "1.0.0",
  "title": "CTA Columns",
  "category": "aludra",
  "icon": "megaphone",
  "description": "Dual call-to-action cards with headings, descriptions, and buttons",
  "keywords": [
    "cta",
    "call to action",
    "buttons",
    "cards",
    "conversion"
  ],
  "textdomain": "aludra",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "supports": {
    "align": [
      "wide",
      "full"
    ],
    "anchor": true,
    "spacing": {
      "margin": true,
      "padding": true
    }
  },
  "attributes": {
    "align": {
      "type": "string",
      "default": "full"
    },
    "colorVariant": {
      "type": "string",
      "default": "default"
    },
    "revealOnScroll": {
      "type": "boolean",
      "default": false
    },
    "style": {
      "type": "object",
      "default": {
        "spacing": {
          "margin": {
            "top": "0",
            "bottom": "0"
          }
        }
      }
    }
  },
  "example": {
    "attributes": {}
  }
}