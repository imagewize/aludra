{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "aludra/review-profiles",
  "version": "1.0.0",
  "title": "Review Profiles",
  "category": "aludra",
  "icon": "groups",
  "description": "Full-width client review section with a heading and a row of round avatar photos with quotes — colours adapt to the active theme's palette.",
  "keywords": [
    "reviews",
    "testimonials",
    "clients",
    "avatars"
  ],
  "example": {},
  "supports": {
    "html": false,
    "align": [
      "wide",
      "full"
    ],
    "anchor": true,
    "spacing": {
      "margin": true,
      "padding": true
    },
    "color": {
      "background": true,
      "text": true
    }
  },
  "textdomain": "aludra",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "attributes": {
    "align": {
      "type": "string",
      "default": "full"
    },
    "style": {
      "type": "object",
      "default": {
        "spacing": {
          "margin": {
            "top": "0",
            "bottom": "0"
          }
        }
      }
    }
  }
}