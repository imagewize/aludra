{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "aludra/services-block",
  "version": "1.0.0",
  "title": "Services Block",
  "category": "aludra",
  "icon": "list-view",
  "description": "Section header with a two-per-row grid of icon, heading, and text service cards — colours adapt to the active theme's palette.",
  "keywords": [
    "services",
    "features",
    "icon",
    "grid",
    "cards"
  ],
  "example": {},
  "supports": {
    "html": false,
    "align": [
      "wide",
      "full"
    ],
    "anchor": true,
    "spacing": {
      "margin": true,
      "padding": true
    },
    "color": {
      "background": true,
      "text": true
    }
  },
  "textdomain": "aludra",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "attributes": {
    "align": {
      "type": "string",
      "default": "full"
    },
    "style": {
      "type": "object",
      "default": {
        "spacing": {
          "margin": {
            "top": "0",
            "bottom": "0"
          }
        }
      }
    }
  }
}